    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "@clerk/nextjs": "^7.5.12",
    "@clerk/themes": "^2.4.57",
    "@paper-design/shaders-react": "^0.0.72",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.7.0",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^2.4.1",
    "next": "16.2.2",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "posthog-js": "^1.369.0",
    "posthog-node": "^5.21.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0"
